# Bloom — Local Productivity Suite
# Copy this file to .env and fill in your own values.

# A random string used as extra salt for password vault encryption.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_VAULT_SALT=replace_with_your_random_hex_string

# App display name (shown in the navbar and PWA)
VITE_APP_NAME=Bloom
